# =============================================================
# Copy this file to .env and fill in your values
# =============================================================

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Your AgentPhone webhook signing secret (from your AgentPhone dashboard)
# Optional but recommended for security
AGENTPHONE_WEBHOOK_SECRET=

# Google OAuth token (for Railway / hosted deploys)
# Run the OAuth flow locally first (Step 6 in README), then paste the
# contents of your token.json file here as a single line.
# GOOGLE_TOKEN_JSON={"token": "...", "refresh_token": "...", ...}
